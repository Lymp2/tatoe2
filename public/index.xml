    <item>
      <title>Libby - Page 2</title>
      <link>http://localhost:1313/libby/page2/</link>
      <pubDate>Mon, 27 Jan 2025 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/libby/page2/</guid>
      <description>&lt;h1 id=&#34;page-2&#34;&gt;Page 2&lt;/h1&gt;
&lt;p&gt;This is the second private page in the Libby section.&lt;/p&gt;
&lt;h2 id=&#34;private-information&#34;&gt;Private Information&lt;/h2&gt;
&lt;p&gt;This page can contain any private information you want to share with specific people.&lt;/p&gt;
&lt;h3 id=&#34;use-cases&#34;&gt;Use Cases&lt;/h3&gt;
&lt;ul&gt;
&lt;li&gt;&lt;strong&gt;Private documentation&lt;/strong&gt;&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;Internal notes&lt;/strong&gt;&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;Draft content&lt;/strong&gt;&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;Personal resources&lt;/strong&gt;&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;Confidential information&lt;/strong&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;h3 id=&#34;security-notes&#34;&gt;Security Notes&lt;/h3&gt;
&lt;ul&gt;
&lt;li&gt;Pages are not indexed by search engines&lt;/li&gt;
&lt;li&gt;Not listed in site navigation&lt;/li&gt;
&lt;li&gt;Only accessible via direct links&lt;/li&gt;
&lt;li&gt;Can be password protected at the hosting level if needed&lt;/li&gt;
&lt;/ul&gt;
&lt;hr&gt;
&lt;p&gt;&lt;a href=&#34;http://localhost:1313/libby/&#34;&gt;← Back to Libby&lt;/a&gt;&lt;/p&gt;</description>
    </item>
    <item>
      <title>Libby - Page 3</title>
      <link>http://localhost:1313/libby/page3/</link>
      <pubDate>Mon, 27 Jan 2025 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/libby/page3/</guid>
      <description>&lt;h1 id=&#34;page-3&#34;&gt;Page 3&lt;/h1&gt;
&lt;p&gt;This is the third private page in the Libby section.&lt;/p&gt;
&lt;h2 id=&#34;additional-features&#34;&gt;Additional Features&lt;/h2&gt;
&lt;p&gt;You can customize these pages with any content you need.&lt;/p&gt;
&lt;h3 id=&#34;content-types&#34;&gt;Content Types&lt;/h3&gt;
&lt;ul&gt;
&lt;li&gt;&lt;strong&gt;Text content&lt;/strong&gt;&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;Images&lt;/strong&gt; (upload to static/images/)&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;Links to external resources&lt;/strong&gt;&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;Embedded content&lt;/strong&gt;&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;Downloadable files&lt;/strong&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;h3 id=&#34;example-structure&#34;&gt;Example Structure&lt;/h3&gt;
&lt;pre tabindex=&#34;0&#34;&gt;&lt;code&gt;content/libby/
├── _index.md          # Main Libby page
├── page1.md           # Private page 1
├── page2.md           # Private page 2
├── page3.md           # Private page 3
├── notes.md           # Private notes
└── resources.md       # Private resources
&lt;/code&gt;&lt;/pre&gt;&lt;h3 id=&#34;url-structure&#34;&gt;URL Structure&lt;/h3&gt;
&lt;ul&gt;
&lt;li&gt;Main page: &lt;code&gt;https://tatoe.co.uk/libby/&lt;/code&gt;&lt;/li&gt;
&lt;li&gt;Page 1: &lt;code&gt;https://tatoe.co.uk/libby/page1/&lt;/code&gt;&lt;/li&gt;
&lt;li&gt;Page 2: &lt;code&gt;https://tatoe.co.uk/libby/page2/&lt;/code&gt;&lt;/li&gt;
&lt;li&gt;Page 3: &lt;code&gt;https://tatoe.co.uk/libby/page3/&lt;/code&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;hr&gt;
&lt;p&gt;&lt;a href=&#34;http://localhost:1313/libby/&#34;&gt;← Back to Libby&lt;/a&gt;&lt;/p&gt;</description>
    </item>
    <item>
      <title>Libby - Private Notes</title>
      <link>http://localhost:1313/libby/notes/</link>
      <pubDate>Mon, 27 Jan 2025 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/libby/notes/</guid>
      <description>&lt;h1 id=&#34;private-notes&#34;&gt;Private Notes&lt;/h1&gt;
&lt;p&gt;This is a private notes page for your personal use.&lt;/p&gt;
&lt;h2 id=&#34;quick-notes&#34;&gt;Quick Notes&lt;/h2&gt;
&lt;p&gt;You can use this page to store:&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;Meeting notes&lt;/li&gt;
&lt;li&gt;Ideas and concepts&lt;/li&gt;
&lt;li&gt;Personal reminders&lt;/li&gt;
&lt;li&gt;Draft content&lt;/li&gt;
&lt;li&gt;Private thoughts&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id=&#34;formatting-examples&#34;&gt;Formatting Examples&lt;/h2&gt;
&lt;h3 id=&#34;lists&#34;&gt;Lists&lt;/h3&gt;
&lt;ul&gt;
&lt;li&gt;Bullet points&lt;/li&gt;
&lt;li&gt;Numbered lists&lt;/li&gt;
&lt;li&gt;Nested items&lt;/li&gt;
&lt;/ul&gt;
&lt;h3 id=&#34;emphasis&#34;&gt;Emphasis&lt;/h3&gt;
&lt;p&gt;&lt;strong&gt;Bold text&lt;/strong&gt; and &lt;em&gt;italic text&lt;/em&gt; for emphasis.&lt;/p&gt;
&lt;h3 id=&#34;code&#34;&gt;Code&lt;/h3&gt;
&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;&#34;&gt;&lt;code class=&#34;language-javascript&#34; data-lang=&#34;javascript&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;&lt;span style=&#34;color:#75715e&#34;&gt;// Example code block
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;&lt;span style=&#34;color:#75715e&#34;&gt;&lt;/span&gt;&lt;span style=&#34;color:#66d9ef&#34;&gt;function&lt;/span&gt; &lt;span style=&#34;color:#a6e22e&#34;&gt;hello&lt;/span&gt;() {
&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;    &lt;span style=&#34;color:#a6e22e&#34;&gt;console&lt;/span&gt;.&lt;span style=&#34;color:#a6e22e&#34;&gt;log&lt;/span&gt;(&lt;span style=&#34;color:#e6db74&#34;&gt;&amp;#34;Hello, Libby!&amp;#34;&lt;/span&gt;);
&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;}
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h3 id=&#34;links&#34;&gt;Links&lt;/h3&gt;
&lt;p&gt;&lt;a href=&#34;https://example.com&#34;&gt;Link to external site&lt;/a&gt;&lt;/p&gt;
